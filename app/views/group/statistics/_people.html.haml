= content_for(:filter) do
  = form_tag(group_statistic_path(@group, :people), method: :get, class: "form-inline-search") do
    .d-lg-flex.justify-content-between.gap-3
      .d-lg-inline-flex.gap-3.align-items-end
        .mb-3
          = direct_filter_date(:date, t(".date"), value: statistic.filter_params[:date] || f(statistic.stichtag), data: { submit: true })
        - if statistic.has_subgroups?
          .mb-3.form-check
            = hidden_field_tag :include_subgroups, "false", id: :include_subgroups_hidden
            = check_box_tag :include_subgroups, "true", statistic.include_subgroups?, class: "form-check-input", data: { submit: true }
            = label_tag :include_subgroups, t(".include_subgroups"), class: "form-check-label"

= render_card title: t('.overview') do
  %dl.row
    - rows = [ |
      { label_key: t('.total_count'), value: statistic.total_count }, |
      { label_key: t('.magazine_subscribers_count'), value: statistic.magazine_subscribers_count } |
    ] |
    = render partial: 'overview_row', collection: rows, as: :row
    %p.text-muted.small= t('.magazine_subscribers_hint')
.row
  .col-lg-6
    = render_card statistic.language_breakdown, title: t('.language_title') do |breakdown|
      %table.table.table-bordered.text-end
        %colgroup
          %col{style: "width: 40%"}
          %col{style: "width: 20%"}
          %col{style: "width: 40%"}
        %thead
          %tr
            %th.text-start= t('.language')
            %th= t('.count')
            %th= t('.share')
        %tbody
          - breakdown.each do |bucket|
            %tr
              %td.text-start= bucket.label
              %td= bucket.count
              %td= number_to_percentage(bucket.percent, precision: 1)
  .col-lg-6
    = render_card statistic.gender_breakdown, title: t('.gender_title') do |gender_breakdown|
      %table.table.table-bordered.text-end
        %colgroup
          %col{style: "width: 40%"}
          %col{style: "width: 20%"}
          %col{style: "width: 40%"}
        %thead
          %tr
            %th.text-start= t('.gender')
            %th= t('.count')
            %th= t('.share')
        %tbody
          - gender_breakdown.each do |bucket|
            %tr
              %td.text-start= bucket.label
              %td= bucket.count
              %td= number_to_percentage(bucket.percent, precision: 1)

= render_card statistic.age_groups, title: t('.age_structure_title') do |age_groups|
  %table.table.table-bordered.text-end
    %colgroup
      %col{style: "width: 15%"}
      %col{style: "width: 10%"}
      %col{style: "width: 15%"}
      %col{style: "width: 60%"}
    %thead
      %tr
        %th
        %th= t('.count')
        %th
          %span.pe-2= t('.share')
    %tbody
      - age_groups.each do |bucket|
        %tr
          %td= bucket.label
          %td= bucket.count
          %td= number_to_percentage(bucket.percent, precision: 1)
          %td
            .progress.ms-2
              .progress-bar{style: "width: #{distribution_bar_width(bucket.percent / 100.0, 1.0)}"}
