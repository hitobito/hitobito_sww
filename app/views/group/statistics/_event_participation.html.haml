= content_for(:filter) do
  = form_tag(group_statistic_path(@group, :event_participation), method: :get, class: "form-inline-search statistics-filter", role: "search", remote: true, data: { spin: true }) do
    .d-lg-flex.justify-content-between.gap-3
      .d-lg-inline-flex.gap-3.align-items-end
        .mb-3
          = direct_filter_date(:from, t(".from"), value: statistic.filter_params[:from] || f(statistic.from_date), data: { submit: true })
        .mb-3
          = direct_filter_date(:to, t(".to"), value: statistic.filter_params[:to] || f(statistic.to_date), data: { submit: true })
        .mb-3.form-check
          = hidden_field_tag :include_sublayers, "false", id: :include_sublayers_hidden
          = check_box_tag :include_sublayers, "true", statistic.filter_params[:include_sublayers] != "false", class: "form-check-input", data: { submit: true }
          = label_tag :include_sublayers, t(".include_sublayers"), class: "form-check-label"

.row
  .col-lg-6
    .card.mb-3
      .card-header
        %h3.card-title= t('.events_overview')
      .card-body
        - if statistic.events_count.positive?
          %dl.row
            - rows = [ |
              { label_key: t('.total_events'), value: statistic.events_count }, |
              { label_key: t('.total_participations'), value: statistic.total_participations }, |
              { label_key: t('.participations_with_membership'), value: statistic.participations_with_membership, nested: true }, |
              { label_key: t('.participations_without_membership'), value: statistic.participations_without_membership, nested: true }, |
              { label_key: t('.participations_guests'), value: statistic.participations_guests, nested: true }, |
              { label_key: t('.unique_participants'), value: statistic.unique_participants_count }, |
              { label_key: t('.average_participants'), value: statistic.average_participants.round(1) } |
            ] |

            = render partial: 'overview_row', collection: rows, as: :row
        - else
          %p.text-muted=ti(:no_list_entries)
  .col-lg-6
    .card.mb-3
      .card-header
        %h3.card-title= t('.participation_frequency_title')
      .card-body
        - freq = statistic.participation_frequency
        - if freq.any?
          - total_persons = freq.values.sum
          - max_persons = freq.values.max
          %table.table.table-bordered.text-end
            %colgroup
              %col{style: "width: 5%"}
              %col{style: "width: 10%"}
              %col{style: "width: 15%"}
              %col{style: "width: 70%"}
            %thead
              %tr
                %th
                %th= t('.number_of_people')
                %th
                  %span.pe-2=t('.share')
            %tbody
              - freq.each do |times, persons|
                %tr
                  %td= t('.times_count', count: times)
                  %td= persons
                  %td= number_to_percentage(persons.to_f / total_persons * 100, precision: 2)
                  %td
                    .progress.ms-2
                      .progress-bar{style: "width: #{distribution_bar_width(persons.to_f / max_persons, 1.0)}"}
        - else
          %p.text-muted= ti(:no_list_entries)
