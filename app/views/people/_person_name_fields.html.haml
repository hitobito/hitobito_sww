-# locals: (f:)

- entry.decorate.used_attributes(:first_name, :last_name).each do |attr|
  - if controller.permitted_attrs.include?(attr.to_sym)
    = f.labeled_input_field(attr)
  - else
    = f.labeled(attr) do
      %p.form-control-plaintext= entry.send(attr)
= f.labeled_input_fields(*entry.decorate.used_attributes(:nickname))
- entry.decorate.used?(:company_name) do
  = f.labeled_input_field(:company_name,
                           placeholder: I18n.t('global.search.placeholder_company_name'),
                           data: { provide: 'entity',
                                   url: query_company_name_path })
- entry.decorate.used?(:company) do
  = f.labeled_boolean_field :company
